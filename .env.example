# File config chain & token
CHAINS_FILE=chains.json
TOKENS_FILE=tokens.json

# Tampilkan nilai USD (true/false). Harga dari CoinGecko
SHOW_USD=true

# File berisi private key (satu per baris). JANGAN taruh private key di .env
PRIVATE_KEYS_FILE=privatekey.txt

# Wallet tujuan (menu 4: kirim max native single chain)
DESTINATION_ADDRESS=0xb54a1c7873649062f6fbb305b163eb9659347f08

# --- RPC per chain (isi yang dipakai saja, kosongkan yang tidak dipakai) ---
